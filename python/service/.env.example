JWT_AUDIENCE=capabilities
ENV=development
LOG_LEVEL=info
PORT=8900

# ── Database ─────────────────────────────────────────────────────────────────
# Superuser for Alembic migrations; restricted app role for the running service.
# Required: leave blank to force explicit configuration.
MIGRATION_DATABASE_URL=
APP_DATABASE_URL=
# Example only:
# MIGRATION_DATABASE_URL=postgresql+psycopg://template:superuser_password@localhost:5432/python_template
# APP_DATABASE_URL=postgresql+psycopg://app:app_password@localhost:5432/python_template

# ── JWT Public Key ───────────────────────────────────────────────────────────
# Must match the JWT issuer used in your environment. (base64-encoded PEM)
# JWT_PUBLIC_KEY_PEM=

TRUSTED_PROXY_HOPS=0
AUTHORIZATION_POLICIES_DIR=policies
AUTHORIZATION_POLICY_CACHE_TTL=60
MAX_CONTENT_LENGTH=16384
RATELIMIT_STORAGE_URI=memory://
HEALTH_RATE_LIMIT=600 per minute
DOCUMENT_READ_RATE_LIMIT=60 per minute
DOCUMENT_DELETE_RATE_LIMIT=10 per minute
WEB_CONCURRENCY=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=30
GUNICORN_KEEPALIVE=5
JWT_JWKS_URI=http://identity:8014/.well-known/jwks.json
