SERVICE_NAME=service-template
ENV=development
LOG_LEVEL=info
PORT=8018
TRUSTED_PROXY_HOPS=0
AUTHORIZATION_POLICIES_DIR=policies
AUTHORIZATION_POLICY_CACHE_TTL=60
MAX_CONTENT_LENGTH=16384
RATELIMIT_STORAGE_URI=memory://
HEALTH_RATE_LIMIT=600 per minute
DOCUMENT_READ_RATE_LIMIT=60 per minute
DOCUMENT_DELETE_RATE_LIMIT=10 per minute
WEB_CONCURRENCY=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=30
GUNICORN_KEEPALIVE=5
