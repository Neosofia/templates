{
  "demo": {
    "entityTypes": {
      "Patient": {
        "shape": {
          "type": "Record",
          "attributes": {}
        }
      },
      "Clinician": {
        "shape": {
          "type": "Record",
          "attributes": {
            "role": { "type": "String", "required": true },
            "clinic_id": { "type": "String", "required": true }
          }
        }
      },
      "Document": {
        "shape": {
          "type": "Record",
          "attributes": {
            "owner": { "type": "Entity", "name": "Patient", "required": true },
            "clinic_id": { "type": "String", "required": true }
          }
        }
      }
    },
    "actions": {
      "document:read": {
        "appliesTo": {
          "principalTypes": ["Patient", "Clinician"],
          "resourceTypes": ["Document"],
          "context": {
            "type": "Record",
            "attributes": {
              "http_method": { "type": "String", "required": true },
              "route": { "type": "String", "required": true }
            }
          }
        }
      },
      "document:delete": {
        "appliesTo": {
          "principalTypes": ["Clinician"],
          "resourceTypes": ["Document"],
          "context": {
            "type": "Record",
            "attributes": {
              "http_method": { "type": "String", "required": true },
              "route": { "type": "String", "required": true }
            }
          }
        }
      }
    }
  }
}
