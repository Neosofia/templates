# SQL audit template image used by services that need shared audit SQL assets.
FROM scratch

COPY audit /sql/audit

LABEL org.opencontainers.image.title="sql-template"
LABEL org.opencontainers.image.description="SQL audit templates for Neosofia services"
LABEL org.opencontainers.image.source="https://github.com/Neosofia/templates"
LABEL org.opencontainers.image.licenses="Apache-2.0"
